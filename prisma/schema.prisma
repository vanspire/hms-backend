generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum AppointmentStatus {
  BOOKED
  CHECKED_IN
  ACKNOWLEDGED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  UNPAID
}

enum PaymentMode {
  CASH
  CREDIT
  UPI
  STRIPE
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  role          Role
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctorProfile DoctorProfile?
  receptionist  ReceptionistProfile?
  adminProfile  AdminProfile?
}

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  phone       String?  @db.VarChar(15)
  // Store enabled modules as array of strings, e.g., ["dashboard", "doctors", "patients"]
  permissions Json     @default("[]")
  
  user        User     @relation(fields: [userId], references: [id])
}

model DoctorProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  name                  String
  departmentId          String
  phone                 String   @db.VarChar(15)
  consultationFee       Float
  incrementIntervalDays Int
  renewalCharge         Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  user                  User     @relation(fields: [userId], references: [id])
  department            Department @relation(fields: [departmentId], references: [id])
  slots                 Slot[]
  appointments          Appointment[]
  visits                Visit[]
}

model ReceptionistProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  phone     String   @db.VarChar(15)
  
  user      User     @relation(fields: [userId], references: [id])
}

model Patient {
  id                      String   @id @default(uuid())
  userId                  String?  @unique
  uhid                    String   @unique
  name                    String
  firstName               String?
  lastName                String?
  age                     Int
  dob                     DateTime?
  gender                  String?
  registrationDate        DateTime @default(now())

  // Structured address fields
  houseNumber             String?
  houseName               String?
  houseAddress            String?
  localArea               String?
  street                  String?
  city                    String?
  state                   String?
  pincode                 String?

  // Legacy combined address for backward compat
  address                 String?  @db.Text
  contactNo               String?  @db.VarChar(15)
  alternateContact        String?  @db.VarChar(15)
  email                   String?

  guardianName            String?
  guardianRelation        String?
  guardianContact         String?  @db.VarChar(15)
  guardianComment         String?  @db.Text
  guardianAddress         String?  @db.Text

  referredDoctor          String?
  referredHospital        String?

  idProofType             String?
  idProofDetail           String?
  idProofData             String?  @db.Text

  registrationAmount      Float?   @default(200)
  registrationPaymentStatus PaymentStatus @default(UNPAID)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  appointments            Appointment[]
  prescriptions           Prescription[]
  medicalReports          MedicalReport[]
  invoices                Invoice[]
  visits                  Visit[]
}

model Visit {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  patientId     String
  doctorId      String

  chiefComplaint  String?  @db.Text
  diagnosis       String?  @db.Text
  medications     Json?
  notes           String?  @db.Text
  status          String   @default("in_progress") // in_progress | completed

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id])
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
}

model Slot {
  id           String   @id @default(uuid())
  doctorId     String
  startTime    DateTime
  endTime      DateTime
  maxCapacity  Int      @default(1)
  bookedCount  Int      @default(0)
  isAvailable  Boolean  @default(true)
  version      Int      @default(1) // For optimistic locking / race condition prevention

  doctor       DoctorProfile @relation(fields: [doctorId], references: [id])
  appointments Appointment[]
}

model Appointment {
  id              String   @id @default(uuid())
  token           String   @unique
  patientId       String
  doctorId        String
  slotId          String
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(BOOKED)
  
  totalAmount     Float
  paidAmount      Float    @default(0)
  pendingAmount   Float
  paymentStatus   PaymentStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient       @relation(fields: [patientId], references: [id])
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id])
  slot            Slot          @relation(fields: [slotId], references: [id])
  payments        Payment[]
  invoice         Invoice?
  prescription    Prescription?
  visit           Visit?
}

model Payment {
  id              String   @id @default(uuid())
  appointmentId   String
  amount          Float
  paymentMode     PaymentMode
  transactionId   String?
  status          String   // e.g., SUCCESS, FAILED
  paymentDate     DateTime @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id])
}

model Invoice {
  id              String   @id @default(uuid())
  appointmentId   String   @unique
  patientId       String
  totalAmount     Float
  taxAmount       Float?
  netAmount       Float
  issuedDate      DateTime @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  patient         Patient     @relation(fields: [patientId], references: [id])
}

model Prescription {
  id              String   @id @default(uuid())
  appointmentId   String   @unique
  patientId       String
  diagnosisNotes  String   @db.Text
  medications     Json     // e.g., [{ name, dosage, frequency, days }]
  issuedDate      DateTime @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  patient         Patient     @relation(fields: [patientId], references: [id])
}

model MedicalReport {
  id              String   @id @default(uuid())
  patientId       String
  reportType      String
  description     String?  @db.Text
  fileUrl         String
  uploadedDate    DateTime @default(now())

  patient         Patient  @relation(fields: [patientId], references: [id])
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text

  doctors     DoctorProfile[]
}

model Organization {
  id               String   @id @default(uuid())
  organizationName String
  timezone         String   @default("UTC")
  currency         String   @default("USD")
  logoUrl          String?
  address          String?  @db.Text
  contactEmail     String?
  contactPhone     String?
  
  updatedAt        DateTime @updatedAt
}
